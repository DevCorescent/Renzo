DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"
JWT_SECRET="replace-with-a-long-random-secret"

# Cloudflare R2 Object Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Google sign-in (customer login only) — Google Cloud Console → Credentials →
# OAuth 2.0 Client ID (type: Web application).
# Authorised JavaScript origins must include http://localhost:3000 and your prod origin.
# Server-side: the audience the ID token is verified against.
GOOGLE_CLIENT_ID=""
# Not used by the ID-token flow, but kept for future server-side OAuth exchanges.
GOOGLE_CLIENT_SECRET=""
# Same value as GOOGLE_CLIENT_ID — the browser needs it to render the GIS button.
# A client id is public by design; the secret above must never be exposed.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Groq AI — https://console.groq.com/keys
GROQ_API_KEY=""