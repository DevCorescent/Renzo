DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="generate-a-long-random-secret"

# Google sign-in (customer login only)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Same value as GOOGLE_CLIENT_ID — the browser needs it to render the GIS button.
# A client id is public by design; the secret above must never be exposed.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# Cloudflare R2 Object Storage
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="renzo"
R2_PUBLIC_URL="https://YOUR_BUCKET_PUBLIC_HOST.r2.dev"

# Groq AI (optional — AI features return 503 when unset)
GROQ_API_KEY=""
